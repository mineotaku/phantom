# Phantom relay server configuration.
DATABASE_URL=sqlite:///./phantom.db
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=notifications@example.com
SMTP_PASSWORD=replace_with_smtp_app_password
OTP_TTL_SECONDS=300
CORS_ALLOWED_ORIGIN=https://your-production-domain.example
HOST=127.0.0.1
PORT=8080

# Development only. Never enable this in production because it returns OTPs
# in API responses when SMTP is unavailable.
EXPOSE_DEV_OTP=false
